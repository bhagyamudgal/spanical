{
    "name": "spanical",
    "private": true,
    "type": "module",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "build": "turbo build",
        "dev": "turbo dev",
        "dev:cli": "bun packages/cli/src/index.ts",
        "test": "turbo test",
        "lint": "turbo lint",
        "typecheck": "turbo typecheck",
        "clean": "turbo clean",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepare": "husky"
    },
    "devDependencies": {
        "turbo": "^2.3.0",
        "prettier": "^3.6.2",
        "husky": "^9.1.7",
        "lint-staged": "^16.1.2"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "packageManager": "bun@1.3.11",
    "lint-staged": {
        "**/*": "prettier --write --ignore-unknown"
    }
}
